# ── Node.js ────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.log

# ── Environment Files (NEVER commit real secrets) ──────────────────────────
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local
backend/.env
worker/.env
frontend/.env
frontend/.env.local

# ── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
*.egg
.pytest_cache/

# ── Redis Windows Binaries (use Docker instead) ────────────────────────────
redis-win/

# ── Windows Binaries / Debug Symbols ──────────────────────────────────────
*.exe
*.pdb
*.dll
*.zip
*.msi

# ── Docker ─────────────────────────────────────────────────────────────────
.dockerignore

# ── Editor ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── TypeScript ─────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Kubernetes Secrets (NEVER commit) ──────────────────────────────────────
k8s/base/secret.yaml

# ── ArgoCD Credentials ─────────────────────────────────────────────────────
argocd/*.secret.yaml

# ── Misc ───────────────────────────────────────────────────────────────────
# Empty root package-lock.json (each subproject manages its own)
/package-lock.json
